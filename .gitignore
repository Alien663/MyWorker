## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# Visual Studio 2017 cache/options directory
.vs/

# Rider temporary files
.idea/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent_*.log
nunit-console_*.log

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# Folders containing locally installed packages
packages/
# NuGet v3 package cache
.nuget/packages/

# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/

# For files generated by Resharper
_ReSharper*/
*.[Rr]eSharper
**/[Rr]esharper.xml
*.DotSettings.user

# Windows Installer XML (WiX)
*.wixproj.user
*.wixpdb

# Visual Studio Code
.vscode/

# Covers JetBrains Rider's generated files
.idea/

# Mac files
.DS_Store

# FAKE - F# Make
.fake/

# Paket dependency manager
.paket/paket.bootstrapper.exe
paket-files/

# Cache files for F# Interactive
.fsi_history

# CodeRush
.cr/

# Python - VScode
.python_history/
.ipynb_checkpoints

# Env files
.env
.env.development
.env.production
.env.test
.env.local

# Secrets
secrets.json
appsettings.Development.json
